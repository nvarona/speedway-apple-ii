100 REM SPEEDWAY GAME - VERSION 3.1
110 REM BY SHAKYA DEVELOPMENT
115 REM Adaptacion Natxo Varona
116 REM Para Apple IIe
120 DIM B$(4), RD$(22), OC(22), WP(22), HS(10)
125 B$(0)="<=>"
126 B$(1)="..."
127 B$(2)=".."
128 B$(3)="+ "
129 B$(4)="<0>"
140 TEXT: HOME: GOSUB 530: HOME
150 SC=0: LV=3: SK=0
160 X=11: OX=11
165 REM WP = WALL POSITION (COLUMNA IZQUIERDA DE LA PARED IZQ)
166 REM ANCHO DE CARRETERA FIJO = 14 COLUMNAS
167 CW=14: WD=0
168 REM INICIALIZAR POSICIONES DE PARED EN TODAS LAS FILAS
169 FOR I=1 TO 22: WP(I)=1: RD$(I)="": OC(I)=0: NEXT I
170 HOME
175 GOSUB 600
205 VTAB 9: HTAB X: ? "0";
225 VTAB 24: HTAB 1: ? "SC:";SC;"  LV:";LV;"   ";
230 REM =====================
231 REM    MAIN GAME LOOP
232 REM =====================
240 SP = 600 - (SC * 3): IF SP < 150 THEN SP=150
250 FOR DL=1 TO SP: NEXT DL
255 Q=PEEK(-16384)
265 IF Q>=128 THEN POKE -16368,0: GOSUB 700
268 IF SK<>0 THEN X=X+SK: SK=0
270 REM LIMITAR COCHE DENTRO DE LA CARRETERA EN FILA 9
271 LW9 = WP(9)+3: RW9 = WP(9)+CW-1
272 IF X < LW9 THEN X=LW9
273 IF X > RW9 THEN X=RW9
274 VTAB 9: HTAB OX: ? " ";
276 OX=X
278 REM =====================
279 REM  SCROLL COMPLETO
280 REM =====================
282 FOR I=1 TO 21
283   REM BORRAR FILA I
284   VTAB I: HTAB 1: ? "                              ";
285   REM COPIAR DATOS DE FILA I+1 A FILA I
286   RD$(I)=RD$(I+1): OC(I)=OC(I+1): WP(I)=WP(I+1)
287   REM DIBUJAR PAREDES EN NUEVA POSICION
288   GOSUB 650
289   REM DIBUJAR OBSTACULO SI HAY
290   IF RD$(I)<>"" THEN VTAB I: HTAB OC(I): ? RD$(I);
291 NEXT I
292 REM BORRAR FILA 22
293 VTAB 22: HTAB 1: ? "                              ";
294 REM CALCULAR NUEVA POSICION DE PARED PARA FILA 22
295 REM WD ES LA DIRECCION DEL ZIGZAG (-1, 0, 1)
296 IF INT(4*RND(1))=0 THEN WD = INT(3*RND(1))-1
297 WP(22) = WP(21) + WD
298 REM LIMITAR PARA QUE NO SE SALGA
299 IF WP(22) < 1 THEN WP(22)=1: WD=1
300 IF WP(22) > 8 THEN WP(22)=8: WD=-1
301 REM DIBUJAR PARED EN FILA 22
302 I=22: GOSUB 650
303 RD$(22)=""
304 REM OBSTACULO NUEVO CON PROBABILIDAD 1/3
305 IF INT(3*RND(1))=0 THEN GOSUB 850
306 REM REDIBUJAR COCHE
307 VTAB 9: HTAB X: ? "0";
308 REM COLISION EN FILA 9
310 IF RD$(9)<>"" THEN GOSUB 900
315 SC=SC+1
325 VTAB 24: HTAB 1: ? "SC:";SC;"  LV:";LV;"   ";
330 GOTO 240

500 REM GAME OVER
505 HOME: VTAB 10: HTAB 5: ? "GAME OVER!"
510 VTAB 12: HTAB 3: ? "YOU SCORED: ";SC
515 VTAB 14: HTAB 3: ? "HIT ANY KEY..."
520 POKE -16368,0: FOR DL=1 TO 300: NEXT DL
521 IF PEEK(-16384)<128 THEN 521
525 POKE -16368,0: GOTO 140

530 REM --- PANTALLA PRESENTACION ---
535 POKE -16368,0
540 HOME
545 VTAB 3: HTAB 8: ? "** SPEEDWAY **"
550 VTAB 5: ? "ERES UN BIKER, SE MUESTRA COMO '0'."
555 VTAB 7: ? "EVITA LOS OBJETOS QUE VIENEN HACIA TI:"
560 VTAB 9: ? " '...' = OIL  (TE HACE PATINAR)"
565 VTAB 10: ? " '<=>' = COCHE CONTRARIO"
570 VTAB 11: ? " '<0>' = COCHE CONTRARIO"
575 VTAB 12: ? " '+'   = GRANADA (-2 VIDAS)"
580 VTAB 14: ? "USA FLECHAS IZQUIERDA/DERECHA"
585 VTAB 15: ? "PARA MOVER EL COCHE."
590 VTAB 17: ? "TIENES 3 VIDAS."
595 VTAB 20: HTAB 5: ? "PULSA UNA TECLA PARA JUGAR"
598 POKE -16368,0
599 FOR DL=1 TO 800: NEXT DL
600 Q2=PEEK(-16384)
601 IF Q2<128 THEN 600
602 POKE -16368,0
605 RETURN

600 REM --- DIBUJAR PANTALLA INICIAL ---
601 FOR I=1 TO 22
602   WP(I)=1
603   I2=I: GOSUB 650
604 NEXT I
605 RETURN

650 REM --- DIBUJAR PAREDES EN FILA I ---
651 REM PARED IZQUIERDA: COLUMNAS WP(I) A WP(I)+2
652 VTAB I: HTAB WP(I): ? "XXX";
653 REM ESPACIO CARRETERA
654 VTAB I: HTAB WP(I)+3: ? "              ";
655 REM PARED DERECHA: COLUMNAS WP(I)+3+CW A WP(I)+3+CW+2
656 VTAB I: HTAB WP(I)+3+CW: ? "XXX";
657 RETURN

700 REM --- LEER TECLADO ---
705 IF Q=136 THEN X=X-1
710 IF Q=149 THEN X=X+1
725 RETURN

800 REM --- GENERAR OBSTACULO ---
805 OT = INT(5*RND(1))
807 IF OT<0 THEN OT=0
808 IF OT>4 THEN OT=4
810 REM COLUMNA ALEATORIA DENTRO DE LA CARRETERA EN FILA 22
811 OBC = WP(22)+3 + INT((CW-3)*RND(1))
812 IF OBC < WP(22)+3 THEN OBC=WP(22)+3
813 IF OBC > WP(22)+CW THEN OBC=WP(22)+CW
820 RETURN

850 REM --- PONER OBSTACULO EN FILA 22 ---
851 GOSUB 800
852 RD$(22) = B$(OT)
853 OC(22) = OBC
854 VTAB 22: HTAB OBC: ? B$(OT);
855 RETURN

900 REM --- COLISION EN FILA 9 ---
902 CC=OC(9)
905 IF CC > X+1 THEN RD$(9)="": RETURN
910 IF CC+2 < X THEN RD$(9)="": RETURN
915 REM COLISION REAL
920 IF OT=1 THEN SK=INT(3*RND(1))+1: RD$(9)="": RETURN
925 IF OT=3 THEN LV=LV-2: GOTO 950
930 LV=LV-1
950 FOR I=1 TO 5
960   VTAB 9: HTAB X: ? "***";
965   FOR J=1 TO 150: NEXT J
970   VTAB 9: HTAB X: ? " 0 ";
975   FOR J=1 TO 150: NEXT J
980 NEXT I
985 IF LV<=0 THEN GOTO 500
990 X=11: OX=11: RD$(9)=""
998 RETURN